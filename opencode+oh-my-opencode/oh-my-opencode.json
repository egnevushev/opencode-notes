{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "max",
      "fallback_models": ["openai/gpt-5.3-codex"]
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "variant": "high"
    },
    "librarian": {
      "model": "github-copilot-enterprise/gpt-5.4",
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "fallback_models": ["openai/gpt-5.3-codex"]
    },
    "explore": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "low",
      "textVerbosity": "low",
      "fallback_models": ["github-copilot-enterprise/claude-haiku-4.5"]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": ["openai/gpt-5.3-codex"]
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": ["openai/gpt-5.3-codex"]
    },
    "momus": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high",
      "fallback_models": ["anthropic/claude-opus-4-6"]
    },
    "atlas": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "fallback_models": ["anthropic/claude-sonnet-4-6"]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": ["openai/gpt-5.3-codex"]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "textVerbosity": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "writing": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    }
  },
  "background_task": {
    "defaultConcurrency": 4,
    "providerConcurrency": {
      "anthropic": 1,
      "openai": 4
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 1,
      "anthropic/claude-sonnet-4-6": 1,
      "openai/gpt-5.3-codex": 4
    },
    "staleTimeoutMs": 180000
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "disabled_mcps": ["websearch", "grep_app"],
  "_migrations": [
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6"
  ]
}
